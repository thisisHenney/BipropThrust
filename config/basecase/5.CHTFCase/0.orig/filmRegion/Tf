FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      Tf;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 1 0 0 0];

internalField   uniform  310;

boundaryField
{
    // extruded boundaries with physical BC
    "(fluid_to_.*)"
    {
        type            zeroGradient;
    }

    // top film surface
    "(.*top)"
    {
        type            zeroGradient;
    }

    // mapped boundaries
//    "(region0_to_.*)"
    wallFilm_to_fluid
    {
//        type            zeroGradient;
        type            mapped;
        field           T;
        average         0;
        setAverage      no;
        value           uniform 310;                
    }
    outlet
    {
	type 	    zeroGradient;
    }
}


